# ============================================================
# 模型部署配置 - 根据你的机器修改这里
# ============================================================

# 模型配置
MODEL_ID="Jackrong/Qwen3.5-27B-Claude-4.6-Opus-Reasoning-Distilled"
MODEL_NAME="qwen3.5-27b"
MODEL_LOCAL_DIR="/data/models/qwen3.5-27b"

# 服务配置
HOST="0.0.0.0"
PORT=8000

# GPU 配置（L20 48GB 单卡）
TENSOR_PARALLEL_SIZE=1
GPU_MEMORY_UTILIZATION=0.92

# 量化配置（L20 48GB 装不下 BF16 的 27B，需要量化）
# 可选: bitsandbytes | awq | gptq | fp8 | none
QUANTIZATION="bitsandbytes"

# 上下文长度（越大越吃显存，根据需要调整）
MAX_MODEL_LEN=32768

# HuggingFace 镜像（国内机器加速下载，境外机器可留空）
HF_ENDPOINT="https://hf-mirror.com"
# HF_ENDPOINT=""

# HuggingFace Token（私有模型需要，公开模型留空）
HF_TOKEN=""